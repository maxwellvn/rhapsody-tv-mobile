# Rhapsody TV Mobile – environment variables
# Copy to .env and set values.
# With Expo, only EXPO_PUBLIC_* variables are available in the app.

# Stripe publishable key (for donations). Must match backend Stripe account.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Optional: set to "1" to enable API request/response debug logs in dev
# EXPO_PUBLIC_API_DEBUG_LOGS=0

# Note: API base URL is set in config/api.config.ts (BASE_URL), not via env.
