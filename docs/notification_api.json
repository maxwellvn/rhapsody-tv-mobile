{
  "openapi": "3.0.0",
  "paths": {
    "/v1/notifications": {
      "get": {
        "operationId": "NotificationsController_getMyNotifications",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Notifications retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiSuccessResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/PaginatedNotificationsDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get my notifications (paginated)",
        "tags": [
          "Notifications"
        ]
      }
    },
    "/v1/notifications/{notificationId}/read": {
      "patch": {
        "operationId": "NotificationsController_markRead",
        "parameters": [
          {
            "name": "notificationId",
            "required": true,
            "in": "path",
            "description": "Notification ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Notification marked as read",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiSuccessResponseDto"
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Mark a notification as read",
        "tags": [
          "Notifications"
        ]
      }
    },
    "/v1/notifications/read-all": {
      "post": {
        "operationId": "NotificationsController_markAllRead",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Notifications marked as read",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiSuccessResponseDto"
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Mark all notifications as read",
        "tags": [
          "Notifications"
        ]
      }
    },
    "/v1/subscriptions/channels/{channelId}": {
      "get": {
        "operationId": "SubscriptionsController_checkSubscription",
        "parameters": [
          {
            "name": "channelId",
            "required": true,
            "in": "path",
            "description": "Channel ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription status retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiSuccessResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/CheckSubscriptionResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Check if the current user is subscribed to a channel",
        "tags": [
          "Subscriptions"
        ]
      },
      "post": {
        "operationId": "SubscriptionsController_subscribe",
        "parameters": [
          {
            "name": "channelId",
            "required": true,
            "in": "path",
            "description": "Channel ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiSuccessResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ChannelSubscriptionResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Subscribe to a channel (creates subscription if missing)",
        "tags": [
          "Subscriptions"
        ]
      }
    },
    "/v1/subscriptions/channels/{channelId}/unsubscribe": {
      "post": {
        "operationId": "SubscriptionsController_unsubscribe",
        "parameters": [
          {
            "name": "channelId",
            "required": true,
            "in": "path",
            "description": "Channel ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unsubscribed from channel successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiSuccessResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ChannelSubscriptionResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Unsubscribe from a channel",
        "tags": [
          "Subscriptions"
        ]
      }
    },
    "/v1/subscriptions/channels/{channelId}/settings": {
      "patch": {
        "operationId": "SubscriptionsController_updateSettings",
        "parameters": [
          {
            "name": "channelId",
            "required": true,
            "in": "path",
            "description": "Channel ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateChannelSubscriptionSettingsDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription settings updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiSuccessResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ChannelSubscriptionResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Update notification settings for a channel subscription",
        "tags": [
          "Subscriptions"
        ]
      }
    }
  },
  "info": {
    "title": "Rhapsody TV API - Notifications",
    "description": "Notification endpoints",
    "version": "1.0",
    "contact": {

    }
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "ApiSuccessResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Operation successful"
          },
          "data": {
            "type": "object",
            "description": "Response payload"
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "NotificationDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "type": {
            "type": "string",
            "enum": [
              "channel_new_video",
              "channel_go_live",
              "channel_new_program",
              "comment_liked",
              "comment_replied"
            ]
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "data": {
            "type": "object"
          },
          "isRead": {
            "type": "boolean",
            "example": false
          },
          "createdAt": {
            "type": "string",
            "example": "2026-01-15T10:00:00.000Z"
          }
        },
        "required": [
          "id",
          "type",
          "title",
          "body",
          "isRead",
          "createdAt"
        ]
      },
      "PaginatedNotificationsDto": {
        "type": "object",
        "properties": {
          "notifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotificationDto"
            }
          },
          "total": {
            "type": "number",
            "example": 100
          },
          "page": {
            "type": "number",
            "example": 1
          },
          "limit": {
            "type": "number",
            "example": 20
          },
          "totalPages": {
            "type": "number",
            "example": 5
          }
        },
        "required": [
          "notifications",
          "total",
          "page",
          "limit",
          "totalPages"
        ]
      },
      "ChannelSubscriptionResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "userId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "channelId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "isSubscribed": {
            "type": "boolean",
            "example": true
          },
          "notifyOnNewVideo": {
            "type": "boolean",
            "example": true
          },
          "notifyOnGoLive": {
            "type": "boolean",
            "example": true
          },
          "notifyOnNewProgram": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "id",
          "userId",
          "channelId",
          "isSubscribed",
          "notifyOnNewVideo",
          "notifyOnGoLive",
          "notifyOnNewProgram"
        ]
      },
      "CheckSubscriptionResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "channelId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "isSubscribed": {
            "type": "boolean",
            "example": true
          },
          "subscription": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ChannelSubscriptionResponseDto"
              }
            ]
          }
        },
        "required": [
          "userId",
          "channelId",
          "isSubscribed"
        ]
      },
      "UpdateChannelSubscriptionSettingsDto": {
        "type": "object",
        "properties": {
          "notifyOnNewVideo": {
            "type": "boolean",
            "default": true
          },
          "notifyOnGoLive": {
            "type": "boolean",
            "default": true
          },
          "notifyOnNewProgram": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}