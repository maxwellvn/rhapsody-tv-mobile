  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "ApiSuccessResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Operation successful"
          },
          "data": {
            "type": "object",
            "description": "Response payload"
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "fullName": {
            "type": "string",
            "example": "John Doe"
          },
          "roles": {
            "type": "array",
            "example": [
              "user"
            ],
            "items": {
              "type": "string",
              "enum": [
                "user",
                "admin"
              ]
            }
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "isEmailVerified": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "id",
          "email",
          "fullName",
          "roles",
          "isActive",
          "isEmailVerified"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "John Doe",
            "description": "Full name of the user"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com",
            "description": "Email address"
          },
          "password": {
            "type": "string",
            "example": "StrongP@ssw0rd",
            "description": "Password (min 8 characters)"
          },
          "roles": {
            "type": "array",
            "example": [
              "user"
            ],
            "description": "User roles",
            "items": {
              "type": "string",
              "enum": [
                "user",
                "admin"
              ]
            }
          }
        },
        "required": [
          "fullName",
          "email",
          "password"
        ]
      },
      "PaginatedUsersResponseDto": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserResponseDto"
            }
          },
          "total": {
            "type": "number",
            "example": 42
          },
          "pages": {
            "type": "number",
            "example": 5
          }
        },
        "required": [
          "users",
          "total",
          "pages"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "John Doe",
            "description": "Full name of the user"
          },
          "roles": {
            "type": "array",
            "example": [
              "user"
            ],
            "description": "User roles",
            "items": {
              "type": "string",
              "enum": [
                "user",
                "admin"
              ]
            }
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the user account is active"
          },
          "isEmailVerified": {
            "type": "boolean",
            "description": "Whether the email has been verified"
          }
        }
      },
      "UserGeneralSettingsDto": {
        "type": "object",
        "properties": {
          "appLanguage": {
            "type": "string",
            "example": "en"
          },
          "autoRotateScreen": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "appLanguage",
          "autoRotateScreen"
        ]
      },
      "UserNotificationSettingsDto": {
        "type": "object",
        "properties": {
          "subscriptions": {
            "type": "boolean",
            "example": true
          },
          "recommendedVideos": {
            "type": "boolean",
            "example": true
          },
          "activityOnMyComments": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "subscriptions",
          "recommendedVideos",
          "activityOnMyComments"
        ]
      },
      "UserQualitySettingsDto": {
        "type": "object",
        "properties": {
          "videoQualityMobile": {
            "type": "string",
            "example": "auto"
          },
          "videoQualityWifi": {
            "type": "string",
            "example": "auto"
          },
          "audioQuality": {
            "type": "string",
            "example": "auto"
          }
        },
        "required": [
          "videoQualityMobile",
          "videoQualityWifi",
          "audioQuality"
        ]
      },
      "UserDownloadSettingsDto": {
        "type": "object",
        "properties": {
          "downloadQuality": {
            "type": "string",
            "example": "medium"
          },
          "downloadOverWifiOnly": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "downloadQuality",
          "downloadOverWifiOnly"
        ]
      },
      "UserSettingsResponseDto": {
        "type": "object",
        "properties": {
          "general": {
            "$ref": "#/components/schemas/UserGeneralSettingsDto"
          },
          "notifications": {
            "$ref": "#/components/schemas/UserNotificationSettingsDto"
          },
          "quality": {
            "$ref": "#/components/schemas/UserQualitySettingsDto"
          },
          "downloads": {
            "$ref": "#/components/schemas/UserDownloadSettingsDto"
          }
        },
        "required": [
          "general",
          "notifications",
          "quality",
          "downloads"
        ]
      },
      "UpdateUserGeneralSettingsDto": {
        "type": "object",
        "properties": {
          "appLanguage": {
            "type": "string",
            "example": "en"
          },
          "autoRotateScreen": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "UpdateUserNotificationSettingsDto": {
        "type": "object",
        "properties": {
          "subscriptions": {
            "type": "boolean",
            "example": true
          },
          "recommendedVideos": {
            "type": "boolean",
            "example": true
          },
          "activityOnMyComments": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "UpdateUserQualitySettingsDto": {
        "type": "object",
        "properties": {
          "videoQualityMobile": {
            "type": "string",
            "example": "auto"
          },
          "videoQualityWifi": {
            "type": "string",
            "example": "auto"
          },
          "audioQuality": {
            "type": "string",
            "example": "auto"
          }
        }
      },
      "UpdateUserDownloadSettingsDto": {
        "type": "object",
        "properties": {
          "downloadQuality": {
            "type": "string",
            "example": "medium"
          },
          "downloadOverWifiOnly": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "UpdateUserSettingsDto": {
        "type": "object",
        "properties": {
          "general": {
            "$ref": "#/components/schemas/UpdateUserGeneralSettingsDto"
          },
          "notifications": {
            "$ref": "#/components/schemas/UpdateUserNotificationSettingsDto"
          },
          "quality": {
            "$ref": "#/components/schemas/UpdateUserQualitySettingsDto"
          },
          "downloads": {
            "$ref": "#/components/schemas/UpdateUserDownloadSettingsDto"
          }
        }
      },
      "WatchlistItemDto": {
        "type": "object",
        "properties": {
          "video": {
            "type": "object"
          },
          "addedAt": {
            "type": "string",
            "example": "2026-01-15T08:00:00.000Z"
          }
        },
        "required": [
          "video",
          "addedAt"
        ]
      },
      "PaginatedWatchlistResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WatchlistItemDto"
            }
          },
          "total": {
            "type": "number",
